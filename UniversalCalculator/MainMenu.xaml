<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Calculator.MainMenu"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Calculator"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

	<Grid Background="LightGray">
		
			<StackPanel Orientation="Vertical" HorizontalAlignment="Center">
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
					<TextBlock Text="Universal Calculator" FontSize="40" Foreground="Black" Height="100" VerticalAlignment="Top" MaxWidth="500"
							TextAlignment="Center"/>
				</StackPanel>

			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
				<Button x:Name="MathCalcButton" Content="Math Calculator" Background="DarkGreen" VerticalAlignment="Top" Width="300" Height="50"
							Margin="10"/>
			</StackPanel>


			
			
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
				<Button x:Name="CurrencyCalcButton" Content="Currency Calculator" Background="Blue" VerticalAlignment="Top" Width="300" Height="50"
						Margin="10" Click="currencyCalcButton_Click"/>
			</StackPanel>

			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
					<Button x:Name="MortgageCalcButton" Content="Mortgage Calculator" Background="Gray" VerticalAlignment="Top" Width="300" Height="50"
							Margin="10" Click="MortgageCalcButton_Click"/>
				</StackPanel>
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
					<Button x:Name="TripCalcButton" Content="Trip Calculator" Background="Gray" VerticalAlignment="Top" Width="300" Height="50"
							Margin="10" Click="TripCalcButton_Click"/>
				</StackPanel>
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
					<Button x:Name="ExitButton" Content="Exit Calculator" Background="Gray" VerticalAlignment="Top" Width="300" Height="50"
							Margin="10" Click="ExitButton_Click"/>
				</StackPanel>
			</StackPanel>
		<Image Source="/Assets/abacus.jpg" HorizontalAlignment="Right" VerticalAlignment="Top" Width="300"/>
	</Grid>

</Page>
